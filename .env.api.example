FAIRYTELLER_API_PORT=3099
FAIRYTELLER_DATA_DIR=/data/fairyteller
FAIRYTELLER_API_TOKEN=replace-with-a-long-random-token
FAIRYTELLER_ALLOWED_ORIGINS=https://fairyteller.ru
FAIRYTELLER_PUBLIC_BASE_URL=https://fairyteller.ru

# Optional: Telegram generation alerts.
FAIRYTELLER_ALERT_TELEGRAM_BOT_TOKEN=replace-with-alert-bot-token
FAIRYTELLER_ALERT_TELEGRAM_CHAT_ID=replace-with-admin-chat-id

# Optional: Telegram website chat replies.
FAIRYTELLER_CHAT_TELEGRAM_BOT_TOKEN=replace-with-chat-bot-token
FAIRYTELLER_CHAT_TELEGRAM_CHAT_ID=replace-with-admin-chat-id
FAIRYTELLER_CHAT_TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-secret
FAIRYTELLER_CHAT_TELEGRAM_POLLING=0

# Legacy fallback: if split variables above are absent, the API still reads
# FAIRYTELLER_TELEGRAM_BOT_TOKEN, FAIRYTELLER_TELEGRAM_CHAT_ID,
# FAIRYTELLER_TELEGRAM_WEBHOOK_SECRET, and FAIRYTELLER_TELEGRAM_POLLING.
