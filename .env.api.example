FAIRYTELLER_API_PORT=3099
FAIRYTELLER_DATA_DIR=/data/fairyteller
FAIRYTELLER_API_TOKEN=replace-with-a-long-random-token
FAIRYTELLER_ALLOWED_ORIGINS=https://fairyteller.ru
FAIRYTELLER_PUBLIC_BASE_URL=https://fairyteller.ru

# Optional: Telegram notifications and website chat replies.
FAIRYTELLER_TELEGRAM_BOT_TOKEN=replace-with-bot-token
FAIRYTELLER_TELEGRAM_CHAT_ID=replace-with-admin-chat-id
FAIRYTELLER_TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-secret
FAIRYTELLER_TELEGRAM_POLLING=0
