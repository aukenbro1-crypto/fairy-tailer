# Frontend submit endpoint.
# Production now uses the same-origin n8n webhook proxy.
VITE_FAIRYTELLER_CREATE_URL=/webhook/fairyteller/create

# Public job status endpoint used when the create endpoint returns only jobId.
VITE_FAIRYTELLER_STATUS_BASE_URL=/api/fairyteller/jobs

# Website support chat API.
VITE_FAIRYTELLER_CHAT_BASE_URL=/api/fairyteller/chat
